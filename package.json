{
  "name": "crossterm-system-theme",
  "version": "0.1.0",
  "description": "Detect system light/dark theme for Node.js CLI and TUI apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/championswimmer/crossterm-system-theme.git"
  },
  "keywords": [
    "crossterm",
    "tui",
    "cli",
    "system-theme",
    "theme",
    "dark-mode"
  ],
  "author": "Arnav Gupta <dev@championswimmer.in>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/championswimmer/crossterm-system-theme/issues"
  },
  "homepage": "https://github.com/championswimmer/crossterm-system-theme#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
